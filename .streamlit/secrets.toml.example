# Streamlit Cloud Secrets Configuration
# 
# This file is a template. DO NOT commit actual secrets to Git!
# 
# For Streamlit Cloud deployment:
# 1. Go to app settings in Streamlit Cloud
# 2. Navigate to Secrets section
# 3. Copy this template and fill in your actual values
#
# For local development:
# 1. Copy this file to .streamlit/secrets.toml
# 2. Fill in your actual values
# 3. Make sure .streamlit/secrets.toml is in .gitignore

[sharepoint]
# Azure AD Application (Client) ID
client_id = "your-client-id-here"

# Azure AD Application Client Secret
client_secret = "your-client-secret-here"

# Azure AD Tenant ID
tenant_id = "your-tenant-id-here"

# SharePoint Site ID
# How to find: Use Graph Explorer or PowerShell
# Example: "yourcompany.sharepoint.com,12345678-1234-1234-1234-123456789012,87654321-4321-4321-4321-210987654321"
site_id = "your-site-id-here"

# SharePoint base folder for SahaID folders (optional)
base_folder = "/Documents"

# SharePoint path for Master.xlsx (optional)
master_path = "/Documents/Master.xlsx"

# Enable SharePoint integration
enabled = true
